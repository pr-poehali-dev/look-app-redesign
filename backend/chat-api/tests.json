{
  "tests": [
    {
      "name": "Get messages",
      "method": "GET",
      "path": "/?module=chat&action=messages&chat_id=test_chat",
      "expectedStatus": 200,
      "expectedBody": {"messages": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Send message",
      "method": "POST",
      "path": "/?module=chat",
      "body": {"chat_id": "test_chat", "content": "Привет!", "type": "text"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get online users",
      "method": "GET",
      "path": "/?module=chat&action=online",
      "expectedStatus": 200,
      "expectedBody": {"users": [{"id": "anon"}]},
      "bodyMatcher": "partial"
    },
    {
      "name": "Send signal",
      "method": "POST",
      "path": "/?module=signal",
      "body": {"room_id": "room1", "to_user": "user2", "type": "offer", "payload": {"sdp": "test"}},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get signals",
      "method": "GET",
      "path": "/?module=signal&room_id=room1",
      "expectedStatus": 200,
      "expectedBody": {"signals": []},
      "bodyMatcher": "partial"
    }
  ]
}